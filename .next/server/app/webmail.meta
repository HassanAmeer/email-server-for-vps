{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/webmail/layout,_N_T_/webmail/page,_N_T_/webmail"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/webmail/__PAGE__",
    "/webmail",
    "/_index",
    "/_head"
  ]
}